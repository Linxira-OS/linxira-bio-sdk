{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/bio/runtime-lock.v1.json",
  "title": "Linxira Bio resolved runtime lock",
  "type": "object",
  "required": ["schema_version", "platform", "runtimes"],
  "properties": {
    "schema_version": { "const": "1" },
    "platform": {
      "type": "object",
      "required": ["family", "arch"],
      "properties": {
        "family": { "enum": ["windows", "debian", "arch"] },
        "arch": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "runtimes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "provider_id", "resolved_version", "source_url", "sha256",
          "install_root", "health_check"
        ],
        "properties": {
          "provider_id": { "type": "string", "minLength": 1 },
          "resolved_version": { "type": "string", "minLength": 1 },
          "source_url": { "type": "string", "format": "uri" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "install_root": { "type": "string", "minLength": 1 },
          "health_check": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
