{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/bio/job-request.v2.json",
  "title": "Linxira Bio artifact-aware job request",
  "type": "object",
  "required": ["schema_version", "job_id", "capability", "inputs", "execution"],
  "properties": {
    "schema_version": { "const": "2" },
    "job_id": { "type": "string", "minLength": 1 },
    "capability": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*\\.v[1-9][0-9]*$"
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/inputArtifact" }
    },
    "execution": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["local-cpu", "local-gpu", "hpc", "cloud", "authenticated-browser"]
        }
      },
      "additionalProperties": false
    },
    "parameters": { "type": "object" }
  },
  "$defs": {
    "dataFormat": {
      "enum": [
        "fasta", "fastq", "csv", "tsv", "bed", "gff3", "gtf", "vcf",
        "sam", "bam", "bcf", "cram", "genbank", "embl", "h5ad", "loom", "hdf5",
        "rds", "pdb", "mmcif", "xlsx", "json", "jsonl", "parquet", "zip",
        "unknown"
      ]
    },
    "artifactFile": {
      "type": "object",
      "required": ["file_id", "path", "format", "compression", "size_bytes"],
      "properties": {
        "file_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "format": { "$ref": "#/$defs/dataFormat" },
        "compression": {
          "enum": ["none", "gzip", "bgzip", "bzip2", "xz", "zstd", "zip", "unknown"]
        },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "modified_at": { "type": "string", "format": "date-time" },
        "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "inputArtifact": {
      "type": "object",
      "required": ["artifact_id", "role", "cardinality", "files"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "cardinality": { "enum": ["single", "paired", "batch"] },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactFile" },
          "minItems": 1
        },
        "dataset_id": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "cardinality": { "const": "single" } }, "required": ["cardinality"] },
          "then": { "properties": { "files": { "minItems": 1, "maxItems": 1 } } }
        },
        {
          "if": { "properties": { "cardinality": { "const": "paired" } }, "required": ["cardinality"] },
          "then": { "properties": { "files": { "minItems": 2, "maxItems": 2 } } }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
