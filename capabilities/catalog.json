{
  "schema_version": "1",
  "product": "linxira-bio-sdk",
  "capabilities": [
    {
      "id": "system.doctor.v1",
      "status": "available",
      "category": "system",
      "default_execution": "local-cpu",
      "command": "linxira-bio doctor --json"
    },
    {
      "id": "environment.audit.v1",
      "status": "available",
      "category": "system",
      "default_execution": "local-cpu",
      "command": "linxira-bio environment audit --json"
    },
    {
      "id": "environment.plan.v1",
      "status": "available",
      "category": "system",
      "default_execution": "local-cpu",
      "command": "linxira-bio environment plan <profile> --json"
    },
    {
      "id": "runtime.catalog.v1",
      "status": "available",
      "category": "system",
      "default_execution": "local-cpu",
      "command": "linxira-bio runtime catalog --json"
    },
    {
      "id": "environment.apply.v1",
      "status": "planned",
      "category": "system",
      "default_execution": "local-cpu",
      "requires_explicit_approval": true
    },
    {
      "id": "sequence.stats.v1",
      "status": "available",
      "category": "sequence-io",
      "default_execution": "local-cpu",
      "command": "linxira-bio sequence stats <input.fasta> --json"
    },
    {
      "id": "dataset.inspect.v1",
      "status": "available",
      "category": "data-management",
      "default_execution": "local-cpu",
      "command": "linxira-bio dataset inspect <input> --json",
      "input_formats": [
        "fasta", "fastq", "csv", "tsv", "bed", "gff3", "gtf", "vcf", "sam"
      ],
      "recognized_formats": [
        "bam", "zip", "bcf", "cram", "h5ad", "loom", "hdf5", "rds", "pdb", "mmcif"
      ],
      "output_formats": ["json"]
    },
    {
      "id": "table.export.v1",
      "status": "available",
      "category": "reporting",
      "default_execution": "local-cpu",
      "command": "linxira-bio export table <input.json> <output> --json",
      "input_formats": ["json"],
      "output_formats": ["csv", "tsv", "json", "jsonl", "xlsx"]
    },
    {
      "id": "system.worker.v1",
      "status": "available",
      "category": "system",
      "default_execution": "local-cpu",
      "command": "linxira-bio-worker <job-request.json>"
    },
    {
      "id": "system.gui.v1",
      "status": "experimental",
      "category": "system",
      "default_execution": "local-cpu",
      "command": "linxira-bio-ui"
    },
    {
      "id": "fastq.qc.v1",
      "status": "available",
      "category": "read-qc",
      "default_execution": "local-cpu",
      "command": "linxira-bio fastq qc <input.fastq> --json",
      "input_formats": ["fastq"],
      "output_formats": ["json"]
    },
    {
      "id": "interval.intersect.v1",
      "status": "planned",
      "category": "genome-intervals",
      "default_execution": "local-cpu"
    },
    {
      "id": "alignment.qc.v1",
      "status": "planned",
      "category": "alignment-files",
      "default_execution": "local-cpu"
    },
    {
      "id": "variant.stats.v1",
      "status": "available",
      "category": "variant-calling",
      "default_execution": "local-cpu",
      "command": "linxira-bio variant stats <input.vcf> --json",
      "input_formats": ["vcf"],
      "output_formats": ["json"]
    },
    {
      "id": "sequence.convert.biopython.v1",
      "status": "planned",
      "category": "sequence-io",
      "default_execution": "local-cpu"
    },
    {
      "id": "expression.deseq2.v1",
      "status": "planned",
      "category": "expression",
      "default_execution": "local-cpu"
    },
    {
      "id": "expression.matrix.qc.v1",
      "status": "planned",
      "category": "expression",
      "default_execution": "local-cpu"
    },
    {
      "id": "protein.af2.predict.v1",
      "status": "planned",
      "category": "structural-biology",
      "default_execution": "local-gpu",
      "fallback_execution": ["hpc", "cloud"]
    },
    {
      "id": "protein.af3.server.v1",
      "status": "planned",
      "category": "structural-biology",
      "default_execution": "authenticated-browser",
      "requires_explicit_approval": true
    }
  ]
}
