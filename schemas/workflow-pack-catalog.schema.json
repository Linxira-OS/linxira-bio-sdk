{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/bio/workflow-pack-catalog.v1.json",
  "title": "Linxira Bio workflow pack catalog",
  "type": "object",
  "required": ["schema_version", "sources", "packs"],
  "properties": {
    "schema_version": { "const": "1" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "trust", "enabled_by_default", "requires_signature",
          "requires_install_approval"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "trust": { "enum": ["official", "community"] },
          "enabled_by_default": { "type": "boolean" },
          "requires_signature": { "type": "boolean" },
          "requires_install_approval": { "type": "boolean" },
          "index_url": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      },
      "minItems": 2
    },
    "packs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "capability", "status", "trust", "runtime"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$" },
          "capability": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*\\.v[1-9][0-9]*$"
          },
          "status": { "enum": ["planned", "cataloged", "installable", "deprecated"] },
          "trust": { "enum": ["official", "community"] },
          "runtime": { "enum": ["python", "r", "java", "native"] },
          "manifest": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
