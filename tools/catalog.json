    {
      "id": "conda",
      "display_name": "Conda",
      "category": "runtime-manager",
      "probes": [
        { "program": "conda", "args": ["--version"] }
      ],
      "install": {}
    },
    {
      "id": "miniforge",
      "display_name": "Miniforge",
      "category": "runtime-manager",
      "probes": [
        { "program": "conda", "args": ["info", "--json"], "output_contains": "miniforge" }
      ],
      "install": {
        "windows": {
          "strategy": "official-installer",
          "package": "Miniforge3",
          "source_url": "https://github.com/conda-forge/miniforge/releases",
          "requires_admin": false
        },
        "debian": {
          "strategy": "official-installer",
          "package": "Miniforge3",
          "source_url": "https://github.com/conda-forge/miniforge/releases",
          "requires_admin": false
        },
        "arch": {
          "strategy": "official-installer",
          "package": "Miniforge3",
          "source_url": "https://github.com/conda-forge/miniforge/releases",
          "requires_admin": false
