{
  "schema_version": "1",
  "profiles": [
    {
      "id": "local-core",
      "description": "Built-in Rust capabilities with no external tool requirement",
      "tools": []
    },
    {
      "id": "scripting",
      "description": "Python, R, and Java runtimes for compatible analysis workflows",
      "tools": ["python", "r", "java"]
    },
    {
      "id": "managed-runtimes",
      "description": "User-scoped runtime managers and their Python, R, and Java runtimes",
      "tools": ["uv", "pixi", "rig", "miniforge", "python", "r", "java"]
    },
    {
      "id": "containers",
      "description": "Platform-appropriate local container and Unix execution backends",
      "tools": ["wsl", "docker", "podman"]
    },
    {
      "id": "sequence-search",
      "description": "Local nucleotide and protein database search",
      "tools": ["ncbi-blast", "diamond"]
    },
    {
      "id": "genomics-cli",
      "description": "Common alignment, variant, interval, and mapping tools",
      "tools": ["samtools", "bcftools", "bedtools", "minimap2"]
    },
    {
      "id": "full-local",
      "description": "All currently registered local runtimes and bioinformatics tools",
      "tools": [
        "uv",
        "pixi",
        "rig",
        "miniforge",
        "python",
        "r",
        "java",
        "ncbi-blast",
        "diamond",
        "samtools",
        "bcftools",
        "bedtools",
        "minimap2"
      ]
    }
  ],
