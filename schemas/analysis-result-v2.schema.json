{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/bio/analysis-result.v2.json",
  "title": "Linxira Bio artifact-aware analysis result",
  "type": "object",
  "required": [
    "schema_version", "job_id", "capability", "status", "result", "artifacts",
    "provenance", "diagnostics"
  ],
  "properties": {
    "schema_version": { "const": "2" },
    "job_id": { "type": "string", "minLength": 1 },
    "capability": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*\\.v[1-9][0-9]*$"
    },
    "status": { "enum": ["ok", "error"] },
    "result": { "type": "object" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/outputArtifact" }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    }
  },
  "$defs": {
    "dataFormat": {
      "enum": [
        "fasta", "fastq", "csv", "tsv", "bed", "gff3", "gtf", "vcf",
        "sam", "bam", "bcf", "cram", "genbank", "embl", "h5ad", "loom", "hdf5",
        "rds", "pdb", "mmcif", "xlsx", "json", "jsonl", "parquet", "zip",
        "unknown"
      ]
    },
    "outputArtifact": {
      "type": "object",
      "required": ["artifact_id", "role", "kind", "path"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["table", "plot", "domain-file", "log", "report", "directory"] },
        "path": { "type": "string", "minLength": 1 },
        "format": { "$ref": "#/$defs/dataFormat" },
        "media_type": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 },
        "artifact_id": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "record": { "type": "integer", "minimum": 1 },
        "hint": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "software": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "package_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["engine_version", "execution_mode"],
      "properties": {
        "engine_version": { "type": "string", "minLength": 1 },
        "execution_mode": {
          "enum": ["local-cpu", "local-gpu", "hpc", "cloud", "authenticated-browser"]
        },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "software": {
          "type": "array",
          "items": { "$ref": "#/$defs/software" }
        },
        "input_sha256": {
          "type": "object",
          "additionalProperties": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "dependency_lock_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
