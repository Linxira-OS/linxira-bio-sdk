{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linxira.org/schemas/bio/dataset-manifest.v1.json",
  "title": "Linxira Bio dataset manifest",
  "type": "object",
  "required": [
    "schema_version", "dataset_id", "display_name", "created_at", "files", "validation"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "dataset_id": { "type": "string", "minLength": 1 },
    "display_name": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactFile" },
      "minItems": 1
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "#/$defs/relationship" }
    },
    "validation": { "$ref": "#/$defs/validation" }
  },
  "$defs": {
    "dataFormat": {
      "enum": [
        "fasta", "fastq", "csv", "tsv", "bed", "gff3", "gtf", "vcf",
        "sam", "bam", "bcf", "cram", "genbank", "embl", "h5ad", "loom", "hdf5",
        "rds", "pdb", "mmcif", "xlsx", "json", "jsonl", "parquet", "zip",
        "unknown"
      ]
    },
    "artifactFile": {
      "type": "object",
      "required": ["file_id", "path", "format", "compression", "size_bytes"],
      "properties": {
        "file_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "format": { "$ref": "#/$defs/dataFormat" },
        "compression": {
          "enum": ["none", "gzip", "bgzip", "bzip2", "xz", "zstd", "zip", "unknown"]
        },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "modified_at": { "type": "string", "format": "date-time" },
        "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "relationship": {
      "type": "object",
      "required": ["kind", "members"],
      "properties": {
        "kind": { "enum": ["paired-end", "index-for", "reference-for", "derived-from"] },
        "members": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 2,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 },
        "artifact_id": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "record": { "type": "integer", "minimum": 1 },
        "hint": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["state"],
      "properties": {
        "state": { "enum": ["pending", "valid", "valid-with-warnings", "invalid"] },
        "checked_at": { "type": "string", "format": "date-time" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
